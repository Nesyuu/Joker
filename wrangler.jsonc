{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "joker-hint",
  "main": "src/worker.js",
  "compatibility_date": "2026-07-23",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "ROOMS",
        "class_name": "RoomObject"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["RoomObject"]
    }
  ]
}
